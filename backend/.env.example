FLASK_ENV=development
SECRET_KEY=change-me

# Local development
DATABASE_URL=sqlite:///youthscores.db

# PythonAnywhere MySQL. utf8mb4 is required for Arabic — do not drop it.
# DATABASE_URL=mysql+pymysql://USER:PASSWORD@USER.mysql.pythonanywhere-services.com/USER$youthscores?charset=utf8mb4

# Guards the admin write endpoints. Sent by the caller as the X-Admin-Key header.
# In development it defaults to "dev-admin-key"; set a real secret in production.
ADMIN_API_KEY=change-me

# Push notifications (Firebase Cloud Messaging).
# Leave FIREBASE_CREDENTIALS unset to run notifications in dry-run (logged, not
# sent). Set it to the path of the FCM service-account JSON to send for real.
# FIREBASE_CREDENTIALS=/path/to/serviceAccountKey.json
# FIREBASE_PROJECT_ID=your-firebase-project-id   # optional; read from the JSON otherwise
